# ============================================================
#  IBM Watsonx.ai — Nutrition Agent Configuration
#  Copy this file to .env and fill in your credentials
#  NEVER commit .env to source control
# ============================================================

# IBM Cloud API Key (required)
IBM_API_KEY=your_ibm_cloud_api_key_here

# IBM Watsonx.ai Project ID (required)
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# IBM Watsonx.ai endpoint URL (default: Dallas region)
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite model ID to use
WATSONX_MODEL_ID=ibm/granite-3-3-8b-instruct

# Flask secret key (generate a strong random string)
FLASK_SECRET_KEY=change_this_to_a_strong_random_secret_key

# Flask environment (development | production)
FLASK_ENV=development

# Port for the Flask server
# macOS: port 5000 is reserved by AirPlay Receiver — use 8080 instead
PORT=8080
